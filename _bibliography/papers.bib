@inproceedings{rajesh2026panini,
  abbr        = {ICML},
  bibtex_show = {true},
  selected    = {true},
  title       = {Panini: Continual Learning in Token Space via Structured Memory},
  author      = {Rajesh, S. and Holur, P. S. and Turali, M. Y. and Duan, C. and Roychowdhury, V.},
  booktitle   = {Proceedings of the 43rd International Conference on Machine Learning (ICML)},
  year        = {2026},
  note        = {Accepted as poster. *Equal contribution by Rajesh and Holur.},
  abstract    = {PANINI is a non-parametric continual-learning framework that encodes documents into Generative Semantic Workspaces (GSW)—entity- and event-aware networks of atomic question-answer pairs. A beam-search retrieval procedure (Reasoning Inference Chain Retrieval, RICR) follows multi-hop inference chains through GSWs to assemble compact evidence, achieving top average performance across six QA benchmarks while using 2-30x fewer answer-context tokens than competitive baselines.}
}

